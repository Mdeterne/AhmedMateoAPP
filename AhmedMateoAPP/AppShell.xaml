<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AhmedMateoAPP.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:AhmedMateoAPP"
    Title="AhmedMateoAPP"
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarForegroundColor="red"
    Shell.TabBarTitleColor="red"
    Shell.TabBarUnselectedColor="#B4FFFFFF"
    Shell.TabBarBackgroundColor="{StaticResource Primary}">

    <Shell.TitleView>
        <Image Source="app_logo.png" HeightRequest="44" Margin="0,0,10,0" />
    </Shell.TitleView>

    <TabBar>
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate local:MainPage}"
            Icon="icon_home.svg"
            Route="MainPage" />
        <ShellContent
            Title="Pokedex"
            ContentTemplate="{DataTemplate local:PokedexPage}"
            Icon="icon_pokedex.svg"
            Route="PokedexPage" />
        <ShellContent
            Title="Ajouter"
            ContentTemplate="{DataTemplate local:AddPokemonPage}"
            Icon="icon_add.svg"
            Route="AddPokemonPage" />
        <ShellContent
            Title="Profile"
            ContentTemplate="{DataTemplate local:ProfilePage}"
            Icon="icon_profile.svg"
            Route="ProfilePage" />
    </TabBar>

</Shell>
