<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:AhmedMateoAPP.Models"
             x:Class="AhmedMateoAPP.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <!-- Titre et Sous-titre -->
            <Label Text="Pokédex de Mateo &amp; Ahmed"
                   Style="{StaticResource Headline}"
                   HorizontalOptions="Center"
                   SemanticProperties.HeadingLevel="Level1" />
            <Label Text="Découvrez le monde des Pokémon"
                   Style="{StaticResource SubHeadline}"
                   HorizontalOptions="Center"
                   SemanticProperties.HeadingLevel="Level2" />

            <!-- Deux images côte à côte -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Image Source="pokemon_1.png" HeightRequest="150" Aspect="AspectFit" Grid.Column="0" />
                <Image Source="pokemon_2.png" HeightRequest="150" Aspect="AspectFit" Grid.Column="1" />
            </Grid>

            <!-- Bouton pour la page GIF -->
            <Button Text="Voir une animation" 
                    Clicked="OnShowGifClicked"
                    HorizontalOptions="Fill" />

            <!-- Composant CarouselView avec défilement -->
            <Label Text="Pokémon en vedette" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,20,0,0"/>
            
            <CarouselView x:Name="FeaturedCarousel" 
                          HeightRequest="250"
                          IndicatorView="IndicatorView"
                          Loop="True"
                          PeekAreaInsets="50">
                
                <CarouselView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" 
                                       ItemSpacing="20" 
                                       SnapPointsType="MandatorySingle" 
                                       SnapPointsAlignment="Center" />
                </CarouselView.ItemsLayout>
                
                <CarouselView.ItemTemplate>
                    <DataTemplate x:DataType="models:PokemonItem">
                        <Frame HasShadow="True"
                               BorderColor="Transparent"
                               CornerRadius="15"
                               Margin="10"
                               BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}"
                               HeightRequest="200">
                            
                            <VerticalStackLayout VerticalOptions="Center" Spacing="10">
                                <Image Source="{Binding ImageUrl}" 
                                       HeightRequest="120" 
                                       WidthRequest="120"
                                       Aspect="AspectFit"
                                       HorizontalOptions="Center"/>
                                       
                                <Label Text="{Binding Name}" 
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center" 
                                       TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"/>
                            </VerticalStackLayout>
                            
                        </Frame>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>
            
            <!-- Indicateurs de position pour le carrousel -->
            <IndicatorView x:Name="IndicatorView"
                           IndicatorColor="LightGray"
                           SelectedIndicatorColor="Black"
                           HorizontalOptions="Center"
                           Margin="0, -10, 0, 0"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
